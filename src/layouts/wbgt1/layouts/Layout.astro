---
// src/layouts/Layout.astro
interface Props {
  title: string;
  activeNav: 'home' | 'game' | 'features' | 'prevention';
}

const { title, activeNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 熱中症対策ナビ</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="app-shell">
      <slot />

      <nav class="bottom-nav">
        <a href="/wbgt/" class={activeNav === 'home' ? 'nav-item active' : 'nav-item'}>
          <div class="nav-icon">🏠</div><div class="nav-text">ホーム</div>
        </a>
        <a href="/wbgt/simulation/" class={activeNav === 'game' ? 'nav-item active' : 'nav-item'}>
          <div class="nav-icon">🎮</div><div class="nav-text">ゲーム</div>
        </a>
        <a href="/wbgt/features/" class={activeNav === 'features' ? 'nav-item active' : 'nav-item'}>
          <div class="nav-icon">📋</div><div class="nav-text">機能表</div>
        </a>
      </nav>
    </div>
  </body>
</html>