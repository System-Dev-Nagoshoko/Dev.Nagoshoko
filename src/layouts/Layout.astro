---
// src/layouts/Layout.astro
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* サイト全体で使う共通の文字色や背景色の定義 */
  :root {
    --white: #ffffff;
    --nago-blue: #2582d1;
    --nago-navy: #1a202c;
    --text-sub: #718096;
  }

  body {
    background-color: #f1f5f9;
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
