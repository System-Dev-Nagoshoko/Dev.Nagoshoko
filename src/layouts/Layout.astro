---
// src/layouts/Layout.astro
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <a href="/" class="home-back-btn" title="ホームに戻る">
      <span class="home-icon">🏠</span>
      <span class="home-text">ホームへ戻る</span>
    </a>

    <footer class="site-footer">
      <p>Created by <a href="https://nagoyc.stki.org/" target="_blank" rel="noopener noreferrer">NYC</a></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --white: #ffffff;
    --nago-blue: #2582d1;
    --nago-navy: #1a202c;
    --text-sub: #718096;
  }
  body {
    background-color: #f1f5f9;
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
  }

  /* 🏠 画面右下に固定するホームボタンのデザイン */
  .home-back-btn {
    position: fixed;
    bottom: 24px; /* 画面の下から 24px */
    right: 24px;  /* 画面の右から 24px */
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background-color: var(--nago-blue); /* 目立つように名護商工ブルーに */
    color: var(--white);
    border: none;
    border-radius: 30px; /* 丸みのある押しやすいカプセル形状 */
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow: 0 4px 16px rgba(37, 130, 209, 0.3); /* 青い影をふんわりつけて立体的に */
    transition: all 0.2s ease;
  }

  .home-back-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 130, 209, 0.4);
    background-color: #1e6bb3; /* ホバー時に少し濃い青に */
  }

  .home-icon {
    font-size: 1.1rem;
  }

  /* クレジット用のデザイン */
  .site-footer {
    margin-top: auto;
    padding: 24px 16px 80px; /* 💡 ボタンと被らないように下の余白を広げました */
    text-align: center;
    background-color: transparent;
  }
  .site-footer p {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #94a3b8;
    letter-spacing: 0.05em;
  }
  
  .site-footer a {
    color: #64748b;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }
  .site-footer a:hover {
    color: var(--nago-blue);
  }
</style>
