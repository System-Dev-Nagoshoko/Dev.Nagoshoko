---
// src/layouts/Layout.astro
// 各ページから渡される title を受け取る設定
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <footer class="site-footer">
      <p>Created by <a href="https://nagoyc.stki.org/" target="_blank" rel="noopener noreferrer">NYC</a></p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --white: #ffffff;
    --nago-blue: #2582d1;
    --nago-navy: #1a202c;
    --text-sub: #718096;
  }
  body {
    background-color: #f1f5f9;
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* クレジット用のデザイン */
  .site-footer {
    margin-top: auto;
    padding: 24px 16px;
    text-align: center;
    background-color: transparent;
  }
  .site-footer p {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #94a3b8;
    letter-spacing: 0.05em;
  }
  
  /* 🔗 NYCのリンク専用スタイル */
  .site-footer a {
    color: #64748b;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }
  .site-footer a:hover {
    color: #2582d1;
  }
</style>
