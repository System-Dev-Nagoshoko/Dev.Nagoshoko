    "沖縄県": ["那覇市","宜野湾市","石垣市","浦添市","名護市","糸満市","沖縄市","豊見城市","うるま市","宮古島市","南城市","国頭村","大宜味村","東村","今帰仁村","本部町","恩納村","宜野座村","金武町","伊江村","読谷村","嘉手納町","北谷町","北中城村","中城村","西原町","与那原町","南風原町","渡嘉敷村","座間味村","粟国村","渡名喜村","南大東村","北大東村","伊平屋村","伊是名村","久米島町","八重瀬町","多良間村","竹富町","与那国町"]
  };

  function saveSetting(key: string, value: string) { localStorage.setItem(key, value); }
  function loadSetting(key: string) { return localStorage.getItem(key); }
  function removeSetting(key: string) { localStorage.removeItem(key); }

  const prefSelect = document.getElementById("prefSelect") as HTMLSelectElement;
  const citySelect = document.getElementById("citySelect") as HTMLSelectElement;
  const modeValue = document.getElementById("modeValue");

  function changePref(pref: string, selectedCity = "", resetCity = true) {
    if (!citySelect) return;
    citySelect.innerHTML = "";
    if (!pref || !AREA_DATA[pref]) {
      citySelect.innerHTML = "<option value=''>先に都道府県を選択</option>";
      saveSetting("pref", pref || "");
      if (resetCity) { saveSetting("city", ""); removeSetting("lat"); removeSetting("lon"); }
      return;
    }
    const first = document.createElement("option");
    first.value = ""; first.textContent = "選択してください";
    citySelect.appendChild(first);

    AREA_DATA[pref].forEach((city) => {
      const option = document.createElement("option");
      option.value = city; option.textContent = city;
      citySelect.appendChild(option);
    });
    saveSetting("pref", pref);

    if (selectedCity) {
      citySelect.value = selectedCity;
      saveSetting("city", selectedCity);
    } else if (resetCity) {
      citySelect.value = ""; saveSetting("city", "");
      removeSetting("lat"); removeSetting("lon");
    }
  }

  prefSelect?.addEventListener("change", (e) => {
    changePref((e.target as HTMLSelectElement).value);
  });

  citySelect?.addEventListener("change", (e) => {
    saveSetting("city", (e.target as HTMLSelectElement).value || "");
    removeSetting("lat"); removeSetting("lon");
  });

  document.getElementById("toggleModeBtn")?.addEventListener("click", () => {
    let mode = loadSetting("displayMode") || "通常";
    mode = mode === "通常" ? "シンプル" : "通常";
    saveSetting("displayMode", mode);
    if (modeValue) modeValue.textContent = mode;
  });

  // GPS取得
  document.getElementById("detectLocationBtn")?.addEventListener("click", async () => {
    if (!confirm("現在地を取得して、都道府県と地域を自動設定しますか？")) return;
    if (!navigator.geolocation) { alert("このブラウザは位置情報に対応していません。"); return; }

    navigator.geolocation.getCurrentPosition(async (position) => {
      const lat = position.coords.latitude;
      const lon = position.coords.longitude;
      try {
        const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}&accept-language=ja`;
        const response = await fetch(url);
        const data = await response.json();
        const address = data.address || {};
        let pref = address.state || address.province || "";
        let city = address.city || address.town || address.village || address.municipality || "";

        if (prefSelect && pref) {
          prefSelect.value = pref;
          changePref(pref, city, false);
        }
        saveSetting("pref", pref);
        saveSetting("city", city);
        saveSetting("lat", String(lat));
        saveSetting("lon", String(lon));
        alert(`地域を設定しました：${pref} ${city}`);
      } catch (error) {
        alert("地域の自動取得に失敗しました。");
      }
    });
  });

  // トグル要素バインド
  const toggles = [
    { id: "notifyToggle", key: "notifyEnabled" },
    { id: "alertToggle", key: "alertNotify" },
    { id: "weatherToggle", key: "weatherNotify" },
    { id: "newsToggle", key: "newsNotify" }
  ];

  toggles.forEach(t => {
    const el = document.getElementById(t.id) as HTMLInputElement;
    el?.addEventListener("change", () => {
      saveSetting(t.key, el.checked ? "1" : "0");
    });
  });

  // 設定の復元
  document.addEventListener("DOMContentLoaded", () => {
    const savedPref = loadSetting("pref") || "";
    const savedCity = loadSetting("city") || "";
    const savedMode = loadSetting("displayMode") || "通常";

    if (modeValue) modeValue.textContent = savedMode;
    if (prefSelect && savedPref) {
      prefSelect.value = savedPref;
      changePref(savedPref, savedCity, false);
    }

    toggles.forEach(t => {
      const el = document.getElementById(t.id) as HTMLInputElement;
      if (el) el.checked = loadSetting(t.key) === "1";
    });
  });
</script>

<style is:global>
