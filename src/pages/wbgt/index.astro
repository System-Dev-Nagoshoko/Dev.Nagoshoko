---
import Layout from '../../layouts/wbgt1/layouts/Layout.astro';
---

<Layout title="熱中症対策ナビ">
  <div id="splash-screen" class="splash-screen">
    <div class="splash-inner">
      <img src="/wbgt/icons/favicon-512-v2.png" alt="熱中症対策ナビ" class="splash-logo" />
      <h1 class="splash-title">熱中症対策ナビ</h1>
      <p class="splash-subtitle">Heat Safety Navi</p>
    </div>
  </div>

  <div class="app-shell">
    <header class="site-header">
      <div class="header-inner">
        <div class="site-logo">
          <img src="/wbgt/icons/favicon-512-v2.png" alt="logo" />
        </div>
        <div class="header-text">
          <h1>熱中症対策ナビ</h1>
          <p class="lead" id="currentTime">--/--(--) --:--:--</p>
        </div>
      </div>
    </header>

    <main class="container">
      <section class="card hero-card">
        <div class="hero-badge">本日の確認</div>
        <div class="hero-region" id="currentRegion">地域：未設定</div>
        <h2 id="riskTitle">今日の熱中症リスクを確認</h2>
        <p id="riskText" class="risk-advice">ここに危険度や行動アドバイスが表示されます</p>
        
        <div id="weatherBox" class="weather-box">
          <div class="loading-text">🌀 位置情報を取得して計測中...</div>
        </div>
      </section>

      <section class="card">
        <p class="label">メインメニュー</p>
        <div class="portal-grid">
          <a href="/wbgt/emergency/" class="portal-card">
            <div class="portal-icon">🚑</div>
            <div class="portal-title">119通報確認サイト</div>
          </a>
          <a href="/wbgt/report/" class="portal-card">
            <div class="portal-icon">🌡️</div>
            <div class="portal-title">熱リポ</div>
          </a>
          <a href="https://heat-safety-info.nagoyc.jp/" rel="noopener noreferrer" target="_blank" class="portal-card">
            <div class="portal-icon">📝</div>
            <div class="portal-title">熱中症対策ナビ紹介</div>
          </a>
        </div>
      </section>
    </main>

    <nav class="bottom-nav">
      <a href="/wbgt/" class="nav-item active">
        <div class="nav-icon">🏠</div>
        <div class="nav-text">ホーム</div>
      </a>
      <a href="/wbgt/prevention/" class="nav-item">
        <div class="nav-icon">💧</div>
        <div class="nav-text">熱中症対策</div>
      </a>
      <a href="/wbgt/features/" class="nav-item">
        <div class="nav-icon">📋</div>
        <div class="nav-text">機能表</div>
      </a>
    </nav>
  </div>

  <script is:inline>
    function updateTime() {
      const now = new Date();
      document.getElementById("currentTime").textContent = now.toLocaleString("ja-JP");
    }
    setInterval(updateTime, 1000);
    updateTime();

    function updateRegionLabel() {
      const el = document.getElementById("currentRegion");
      if (!el) return;
      const pref = localStorage.getItem("pref") || "";
      const city = localStorage.getItem("city") || "";
      if (pref && city) {
        el.textContent = `地域：${pref} ${city}`;
      } else if (pref) {
        el.textContent = `地域：${pref}`;
      } else {
        el.textContent = "地域：未設定";
      }
    }
    updateRegionLabel();

    function calcWBGT(temp, humidity) {
      return 0.735 * temp + 0.0374 * humidity + 0.00292 * temp * humidity + 7.619;
    }

    function getRisk(wbgt) {
      if (wbgt >= 31) return ["危険", "運動は中止。外出も極力避ける"];
      if (wbgt >= 28) return ["厳重警戒", "激しい運動は避ける"];
      if (wbgt >= 25) return ["警戒", "こまめな休憩と水分補給"];
      if (wbgt >= 21) return ["注意", "無理せず活動"];
      return ["安全", "通常活動可能"];
    }

    navigator.geolocation.getCurrentPosition(async pos => {
      try {
        const lat = pos.coords.latitude;
        const lon = pos.coords.longitude;
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m`;
        const res = await fetch(url);
        const data = await res.json();
        const temp = data.current.temperature_2m;
        const hum = data.current.relative_humidity_2m;
        const wbgt = calcWBGT(temp, hum);
        const [level, advice] = getRisk(wbgt);

        document.getElementById("weatherBox").innerHTML = `
          <div class="weather-grid">
            <div class="weather-item">🌡️ 気温：<strong>${temp}℃</strong></div>
            <div class="weather-item">💧 湿度：<strong>${hum}%</strong></div>
            <div class="weather-item">⚠️ WBGT（推定）：<strong>${wbgt.toFixed(1)}℃</strong></div>
          </div>
        `;

        const riskTitleEl = document.getElementById("riskTitle");
        riskTitleEl.innerHTML = `危険度：<span class="status-badge status-${level}">${level}</span>`;
        document.getElementById("riskText").textContent = advice;
      } catch (e) {
        document.getElementById("weatherBox").textContent = "データ解析に失敗しました";
      }
    }, () => {
      document.getElementById("weatherBox").textContent = "位置情報の取得に失敗しました。ブラウザの設定を確認してください。";
    });

    window.addEventListener("load", () => {
      const splash = document.getElementById("splash-screen");
      if (!splash) return;
      setTimeout(() => {
        splash.classList.add("hide");
      }, 1000);
    });
  </script>
</Layout>

<style is:global>
  :root {
    --bg-grad-top: #e0f2fe;
    --bg-grad-bottom: #f8fbff;
    --card: #ffffff;
    --text: #1f2937;
    --primary: #2563eb;
    --primary-soft: #dbeafe;
    --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
    --radius: 16px;
    --max: 640px;
    --nav-height: 86px;
  }
  * { box-sizing: border-box; }
  body { margin: 0; font-family: system-ui, sans-serif; color: var(--text); background: linear-gradient(180deg, var(--bg-grad-top) 0%, var(--bg-grad-bottom) 100%); }
  
  /* スプラッシュ画面のスタイル */
  .splash-screen { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: #6c63ff; color: #fff; display: flex; align-items: center; justify-content: center; z-index: 9999; transition: opacity 0.5s ease, visibility 0.5s; text-align: center; }
  .splash-screen.hide { opacity: 0; visibility: hidden; }
  .splash-logo { width: 120px; height: 120px; margin-bottom: 16px; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.15)); }
  .splash-title { margin: 0; font-size: 1.8rem; }
  .splash-subtitle { margin: 4px 0 0; opacity: 0.8; font-size: 1rem; }

  .app-shell { min-height: 100vh; padding-bottom: calc(var(--nav-height) + env(safe-area-inset-bottom) + 18px); }
  .site-header { padding: 16px 14px; background: rgba(255, 255, 255, 0.88); border-bottom: 1px solid #cfe4ff; backdrop-filter: blur(10px); }
  .header-inner { max-width: var(--max); margin: 0 auto; display: flex; align-items: center; gap: 12px; }
  .site-logo img { width: 48px; height: 48px; object-fit: contain; border-radius: 12px; }
  .header-text h1 { margin: 0 0 2px; font-size: 1.3rem; color: #1e3a8a; }
  .header-text .lead { margin: 0; font-size: 0.85rem; color: #4b5563; font-weight: 600; }
  
  .container { max-width: var(--max); margin: 16px auto 0; padding: 0 12px 24px; }
  .card { background: var(--card); border: 1px solid rgba(191, 219, 254, 0.9); border-radius: var(--radius); padding: 18px; box-shadow: var(--shadow); margin-bottom: 16px; }
  .label { margin: 0 0 12px; font-size: 0.85rem; font-weight: 800; color: #0369a1; }
  
  /* ヒーローカード＆ダッシュボード調整 */
  .hero-card { background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%); text-align: center; border-left: 5px solid #2563eb; }
  .hero-badge { display: inline-block; padding: 4px 12px; background: #2563eb; color: #fff; font-size: 0.75rem; font-weight: bold; border-radius: 999px; margin-bottom: 10px; }
  .hero-region { font-size: 0.9rem; color: #4b5563; font-weight: bold; margin-bottom: 8px; }
  #riskTitle { margin: 12px 0 6px; font-size: 1.4rem; color: #1e3a8a; }
  .risk-advice { margin: 0 0 16px; font-size: 0.95rem; color: #374151; font-weight: 500; }
  
  .weather-box { background: rgba(255, 255, 255, 0.8); border: 1px dashed #93c5fd; border-radius: 12px; padding: 12px; font-size: 0.95rem; }
  .weather-grid { display: flex; flex-direction: column; gap: 6px; text-align: left; max-width: 240px; margin: 0 auto; }
  .loading-text { font-weight: 600; color: #2563eb; animation: pulse 1.5s infinite; }

  /* 危険度別バッジカラー */
  .status-badge { padding: 2px 10px; border-radius: 6px; color: #fff; font-weight: bold; font-size: 1.2rem; }
  .status-危険 { background: #dc2626; }
  .status-厳重警戒 { background: #ea580c; }
  .status-警戒 { background: #d97706; }
  .status-注意 { background: #eab308; color: #1f2937; }
  .status-安全 { background: #16a34a; }

  /* ポータルメニューカード */
  .portal-grid { display: flex; flex-direction: column; gap: 12px; }
  .portal-card { display: flex; align-items: center; gap: 16px; padding: 14px 18px; background: #f0f7ff; border: 1px solid #dbeafe; border-radius: 12px; text-decoration: none; color: var(--text); transition: background 0.2s; }
  .portal-card:hover { background: #e0effe; }
  .portal-icon { font-size: 24px; }
  .portal-title { font-size: 1rem; font-weight: bold; color: #1e3a8a; }

  .bottom-nav { position: fixed; left: 0; right: 0; bottom: 0; z-index: 1000; width: 100%; max-width: 520px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 10px 12px calc(10px + env(safe-area-inset-bottom)); background: rgba(255, 255, 255, 0.94); border-top: 1px solid rgba(59, 130, 246, 0.12); box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.06); }
  .nav-item { min-height: 58px; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; text-decoration: none; color: #64748b; }
  .nav-item.active { background: var(--primary-soft); color: var(--primary); font-weight: 800; }
  .nav-icon { font-size: 20px; line-height: 1; }
  .nav-text { font-size: 12px; }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
