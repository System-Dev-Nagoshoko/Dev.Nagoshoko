---
import Layout from '../../layouts/wbgt1/layouts/Layout.astro';

// HTML側で使われている変数を定義
const portalMenus = [
  { link: "/wbgt/emergency/", icon: "🚑", title: "119通報確認サイト" },
  { link: "/wbgt/report/", icon: "🌡️", title: "熱リポ" }
];
---

<Layout title="熱中症対策ナビ" activeNav="home">
  <div class="app-shell">
    <header class="topbar">
      <div class="brand">
        <h1>熱中症対策ナビ</h1>
      </div>
    </header>

    <main class="main-content">
      <div class="card-list">
        {portalMenus.map((item) => (
          <a href={item.link} class="feature-wide-card">
            <div class="emoji">{item.icon}</div>
            <div class="label">{item.title}</div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Layout>
