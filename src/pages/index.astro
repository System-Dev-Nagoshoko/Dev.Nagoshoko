cat << 'EOF' > src/pages/index.astro
---
import Layout from '../layouts/Layout.astro';

const portalMenus = [
  {
    title: "企画・検索",
    icon: "🔍",
    link: "./search/",
    accent: "#00b4d8",
    status: "OPEN",
    wide: false
  },
  {
    title: "熱中症ナビ",
    icon: "☀️", 
    link: "./wbgt/",
    accent: "#ff3366",
    status: "LIVE",
    wide: false
  },
  {
    title: "進行予定",
    icon: "🕒",
    link: "#",
    accent: "#74c69d",
    status: "COMING",
    wide: false
  },
  {
    title: "会場マップ",
    icon: "🗺️",
    link: "#",
    accent: "#7209b7",
    status: "MAP",
    wide: false
  },
  {
    title: "案内・Q&A",
    icon: "📢",
    link: "./info/",
    accent: "#f77f00",
    status: "INFO",
    wide: true
  }
];
---

<Layout title="【第7回商工祭】案内システム">
  <div id="cyber-splash" class="cyber-splash">
    <div class="loader-content">
      <div class="glitch-title" data-text="SHOKOSAI">SHOKOSAI</div>
      <div class="system-status">
        <span class="scanning">SYSTEM SCANNING...</span>
        <div class="progress-bar"><div class="progress-inner"></div></div>
      </div>
    </div>
  </div>

  <div class="cyber-portal">
    <div class="digital-bg"></div>
    <div class="neon-glow"></div>

    <div class="crystal crystal-left">
      <div class="crystal-core"></div>
    </div>
    <div class="crystal crystal-right">
      <div class="crystal-core"></div>
    </div>

    <header class="cyber-header">
      <div class="header-line"></div>
      <h1>第7回商工祭案内システム <span class="ver">v2.0</span></h1>
      <p class="cyber-subtitle">NAGO SHOKO FESTIVAL PORTAL</p>
    </header>

    <main class="portal-container">
      <div class="tile-grid">
        {portalMenus.map((menu) => (
          <a href={menu.link} class={`tile-card ${menu.wide ? 'wide-card' : ''}`} style={`--tile-color: ${menu.accent}`}>
            <div class="tile-edge"></div>
            <div class="tile-icon">{menu.icon}</div>
            <div class="tile-info">
              <span class="tile-status">{menu.status}</span>
              <h2 class="tile-title">{menu.title}</h2>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  window.addEventListener('load', () => {
    const splash = document.getElementById('cyber-splash');
    setTimeout(() => {
      splash.style.opacity = '0';
      setTimeout(() => splash.style.display = 'none', 600);
    }, 2200);
  });
</script>

<style is:global>
  body {
    background-color: #f8fafc !important;
    color: #0f172a !important;
    overflow-x: hidden;
  }
</style>

<style>
  .cyber-portal {
    position: relative;
    min-height: 100vh;
    padding: 20px 16px 100px;
  }

  .digital-bg {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: 
      linear-gradient(rgba(15, 23, 42, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.03) 1px, transparent 1px);
    background-size: 30px 30px;
    z-index: -2;
  }

  .neon-glow {
    position: fixed;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: radial-gradient(circle at center, rgba(37, 130, 209, 0.06) 0%, transparent 60%);
    z-index: -1;
  }

  /* 🛰️ スプラッシュの配置ズレを完全修正（中央絶対キープ） */
  .cyber-splash {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #0a0e17;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
    box-sizing: border-box;
  }
  
  .loader-content {
    text-align: center;
    width: 280px;
    margin: 0 auto;
    display: block;
  }
  
  .glitch-title {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: 0.3em;
    color: #00f2ff;
    position: relative;
    margin: 0 0 20px 0;
    text-align: center;
  }
  
  .system-status {
    font-family: monospace;
    color: #00f2ff;
    font-size: 0.8rem;
    text-align: center;
    display: block;
  }
  
  .progress-bar { 
    height: 2px;
    background: rgba(0, 242, 255, 0.2); 
    margin-top: 10px;
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  
  .progress-inner {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 100%;
    background: #00f2ff;
    animation: load 2s infinite ease-in-out;
  }
  @keyframes load { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

  /* 💎 クリスタル */
  .crystal {
    position: fixed;
    top: 30%;
    width: 40px;
    height: 70px;
    z-index: 5;
    pointer-events: none;
  }

  .crystal-left {
    left: 4%;
    animation: floatLeft 4s infinite ease-in-out;
  }

  .crystal-right {
    right: 4%;
    animation: floatRight 4.5s infinite ease-in-out;
  }

  .crystal-core {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 180, 216, 0.7) 0%, rgba(114, 9, 183, 0.6) 100%);
    clip-path: polygon(50% 0%, 100% 35%, 100% 65%, 50% 100%, 0% 65%, 0% 35%);
    backdrop-filter: blur(2px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 0 20px rgba(0, 180, 216, 0.3);
  }

  @keyframes floatLeft {
    0% { transform: translateY(0) rotate(0deg) scale(1); filter: drop-shadow(0 5px 10px rgba(0,180,216,0.2)); }
    50% { transform: translateY(-15px) rotate(5deg) scale(1.05); filter: drop-shadow(0 20px 20px rgba(0,180,216,0.4)); }
    100% { transform: translateY(0) rotate(0deg) scale(1); filter: drop-shadow(0 5px 10px rgba(0,180,216,0.2)); }
  }

  @keyframes floatRight {
    0% { transform: translateY(0) rotate(0deg) scale(1); filter: drop-shadow(0 5px 10px rgba(114,9,183,0.2)); }
    50% { transform: translateY(-20px) rotate(-5deg) scale(1.03); filter: drop-shadow(0 22px 22px rgba(114,9,183,0.4)); }
    100% { transform: translateY(0) rotate(0deg) scale(1); filter: drop-shadow(0 5px 10px rgba(114,9,183,0.2)); }
  }

  /* 🏗️ ヘッダー */
  .cyber-header { text-align: center; margin-bottom: 40px; padding-top: 20px; }
  .header-line { width: 40px; height: 4px; background: #1e3a8a; margin: 0 auto 15px; box-shadow: 0 2px 8px rgba(30, 58, 138, 0.2); }
  .cyber-header h1 { font-size: 1.4rem; font-weight: 900; margin: 0; letter-spacing: 0.05em; color: #1e3a8a; }
  .ver { font-size: 0.8rem; vertical-align: top; color: #0284c7; }
  .cyber-subtitle { font-size: 0.75rem; color: #64748b; opacity: 0.8; letter-spacing: 0.2em; margin-top: 5px; font-weight: 600; }

  .tile-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    max-width: 500px;
    margin: 0 auto;
  }

  .tile-card {
    position: relative;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    aspect-ratio: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #1e293b;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.03);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-sizing: border-box;
  }

  .tile-card.wide-card {
    grid-column: span 2;
    aspect-ratio: unset;
    height: 84px;
    flex-direction: row;
    justify-content: flex-start;
    padding: 0 24px;
    gap: 16px;
  }

  .tile-card.wide-card .tile-info { text-align: left; }
  .tile-card.wide-card .tile-icon { margin-bottom: 0; font-size: 2.2rem; }

  .tile-card:hover {
    background: #ffffff;
    border-color: var(--tile-color);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
    transform: translateY(-2px);
  }

  .tile-card:active { transform: translateY(1px); box-shadow: 0 4px 10px rgba(15, 23, 42, 0.04); }

  .tile-edge {
    position: absolute;
    top: 0; left: 0; width: 12px; height: 12px;
    border-top: 3px solid var(--tile-color);
    border-left: 3px solid var(--tile-color);
    border-top-left-radius: 4px;
  }

  .tile-icon { font-size: 2.4rem; margin-bottom: 6px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.03)); }
  .tile-info { text-align: center; }
  .tile-status { font-size: 0.65rem; font-weight: 800; color: var(--tile-color); text-transform: uppercase; display: block; margin-bottom: 2px; letter-spacing: 0.05em; }
  .tile-title { margin: 0; font-size: 1.05rem; font-weight: 800; color: #0f172a; letter-spacing: -0.01em; }

  @media (min-width: 768px) {
    .crystal-left { left: calc(50% - 320px); }
    .crystal-right { right: calc(50% - 320px); }
  }

  @media (max-width: 350px) {
    .tile-grid { grid-template-columns: 1fr; }
    .tile-card { aspect-ratio: 16 / 9; }
    .tile-card.wide-card { grid-column: span 1; height: 80px; }
  }
</style>
EOF

# ローカルビルドテスト
npx astro clean && npm run build
