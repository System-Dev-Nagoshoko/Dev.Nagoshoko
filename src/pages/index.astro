---
import Layout from '../layouts/Layout.astro';

const portalMenus = [
  {
    title: "企画・クラス検索",
    description: "展示や体験企画を、場所やリアルタイムの混雑状況からスマートに検索。",
    icon: "🔍",
    link: "./search/",
    accent: "#ff4d20", // 機械科
    status: "OPEN"
  },
  {
    title: "熱中症対策ナビ",
    description: "現在の暑さ指数(WBGT)や、校内の水分補給スポットをリアルタイム案内。",
    icon: "☀️", 
    link: "./wbgt/index.html",
    accent: "#ff9800", // 警戒
    status: "OPEN"
  },
  {
    title: "タイムスケジュール",
    description: "体育館のステージ発表や中庭イベントのタイムラインを網羅。",
    icon: "🕒",
    link: "#",
    accent: "#ffaa1d", // 建築科
    status: "COMING"
  },
  {
    title: "デジタル校内マップ",
    description: "広い実習棟や教室の配置をスマホで確認。現在地からのルート表示。",
    icon: "🗺️",
    link: "#",
    accent: "#59ce5d", // 総合情報科
    status: "COMING"
  },
  {
    title: "商工祭インフォ",
    description: "落とし物、休憩所案内や、運営からの緊急アナウンスを即座に配信。",
    icon: "📢",
    link: "#",
    accent: "#32c5ff", // 商業科
    status: "INFO"
  }
];
---

<Layout title="【第7回商工祭】案内システム">
  <div id="loader-screen" class="loader-screen">
    <div class="loader-content">
      <div class="cyber-spinner"></div>
      <div class="loader-text-group">
        <p class="status-text">CONNECTING TO SYSTEM...</p>
        <div class="progress-bar-container">
          <div class="progress-bar-fill"></div>
        </div>
        <p class="loading-sub">Fetching database for Nago Shoko Festival...</p>
      </div>
    </div>
  </div>

  <div class="cyber-bg-grid"></div>
  <div class="cyber-bg-glow-1"></div>
  <div class="cyber-bg-glow-2"></div>

  <div class="portal-container main-content-fade">
    <header class="hero">
      <div class="hero-top-row">
        <span class="badge-online">● SYSTEM ONLINE</span>
        <span class="version-tag">v2.0.4</span>
      </div>
      <h2 class="hero-title">第7回 商工祭 <span>案内システム</span></h2>
      <p class="hero-subtitle">名護商工の「技術」と「人」を繋ぐポータル</p>
    </header>

    <nav class="menu-grid">
      {portalMenus.map((menu) => (
        <a href={menu.link} class={`portal-card status-${menu.status.toLowerCase()}`} style={`--card-accent: ${menu.accent}`}>
          <div class="card-left">
            <div class="icon-box">
              <span>{menu.icon}</span>
            </div>
          </div>
          <div class="card-right">
            <div class="card-meta">
              <h3>{menu.title}</h3>
              <span class="status-tag">{menu.status}</span>
            </div>
            <p>{menu.description}</p>
          </div>
        </a>
      ))}
    </nav>
  </div>
</Layout>

<script is:inline>
  const loader = document.getElementById('loader-screen');
  if (!sessionStorage.getItem('loaded')) {
    document.body.style.overflow = 'hidden';
    setTimeout(() => {
      loader.classList.add('fade-out');
      document.body.style.overflow = 'visible';
      sessionStorage.setItem('loaded', 'true');
    }, 2200);
  } else {
    loader.style.display = 'none';
  }
</script>

<style is:global>
  /* ⚙️ ローディング用スタイル */
  .loader-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: #0b0f19; display: flex; justify-content: center; align-items: center; z-index: 9999; transition: opacity 0.5s ease, visibility 0.5s; }
  .loader-screen.fade-out { opacity: 0; visibility: hidden; }
  .loader-content { display: flex; flex-direction: column; align-items: center; gap: 20px; width: 80%; max-width: 280px; }
  .cyber-spinner { width: 36px; height: 36px; border: 3px solid rgba(37, 130, 209, 0.1); border-radius: 50%; border-top-color: #2582d1; border-right-color: #2582d1; animation: spin 1s linear infinite; }
  .loader-text-group { width: 100%; text-align: center; }
  .status-text { color: #38bdf8; font-family: monospace; font-size: 0.8rem; font-weight: bold; letter-spacing: 0.15em; margin: 0 0 6px 0; animation: blink 1.5s infinite; }
  .progress-bar-container { width: 100%; height: 4px; background-color: #1e293b; border-radius: 2px; overflow: hidden; }
  .progress-bar-fill { height: 100%; width: 0; background: linear-gradient(90deg, #2582d1, #38bdf8); animation: progress-load 2s ease-in-out forwards; }
  .loading-sub { color: #475569; font-size: 0.6rem; margin: 6px 0 0 0; font-family: monospace; }
  .main-content-fade { animation: content-in 0.6s 1.9s ease-out both; }

  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  @keyframes progress-load { 0% { width: 0%; } 100% { width: 100%; } }
  @keyframes content-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* 🌌 背景演出スタイル */
  body {
    position: relative;
    overflow-x: hidden;
    background-color: #fafbfd; /* ほんのり青みのある清潔感のあるベース白 */
  }
  
  /* 薄いデジタルの網の目を敷く */
  .cyber-bg-grid {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    background-image: 
      linear-gradient(rgba(226, 232, 240, 0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(226, 232, 240, 0.5) 1px, transparent 1px);
    background-size: 30px 30px;
    pointer-events: none;
  }

  /* 画面左上のネオンライト効果 */
  .cyber-bg-glow-1 {
    position: fixed;
    top: -200px;
    left: -200px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 130, 209, 0.07) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  /* 画面右下のネオンライト効果 */
  .cyber-bg-glow-2 {
    position: fixed;
    bottom: -150px;
    right: -150px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.05) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  /* 💻 レイアウト */
  .portal-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 32px 16px 80px;
  }

  .hero-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .badge-online {
    font-family: monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: #22c55e;
    letter-spacing: 0.05em;
  }
  .version-tag {
    font-family: monospace;
    font-size: 0.7rem;
    color: #94a3b8;
  }

  .hero {
    margin-bottom: 28px;
    border-bottom: 1px dashed #e2e8f0;
    padding-bottom: 16px;
  }
  .hero-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0;
  }
  .hero-title span {
    color: #2582d1;
  }
  .hero-subtitle {
    margin: 4px 0 0 0;
    color: #64748b;
    font-size: 0.85rem;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 560px) {
    .menu-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .portal-card:last-child {
      grid-column: span 2;
    }
  }

  /* 🃏 横型スリムサイバーカード (少し透けるガラス質感) */
  .portal-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    border-radius: 14px;
    padding: 16px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.02);
    border: 1px solid rgba(226, 232, 240, 0.8);
    display: flex;
    gap: 14px;
    align-items: flex-start;
    transition: all 0.2s ease;
    position: relative;
  }

  .portal-card::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 0;
    bottom: 12px;
    width: 4px;
    background-color: var(--card-accent);
    border-radius: 0 4px 4px 0;
  }

  .portal-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 130, 209, 0.08);
    border-color: #2582d1;
    background: #ffffff;
  }

  .card-left {
    flex-shrink: 0;
  }
  .icon-box {
    width: 40px;
    height: 40px;
    background: #f8fafc;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    border: 1px solid #e2e8f0;
  }

  .card-right {
    flex-grow: 1;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }
  .card-right h3 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
  }
  .card-right p {
    margin: 0;
    font-size: 0.8rem;
    color: #64748b;
    line-height: 1.4;
  }

  .status-tag {
    font-family: monospace;
    font-size: 0.6rem;
    font-weight: 800;
    padding: 2px 6px;
    border-radius: 6px;
  }
  .status-open .status-tag { background: #dcfce7; color: #15803d; }
  .status-coming .status-tag { background: #f1f5f9; color: #64748b; }
  .status-info .status-tag { background: #e0f2fe; color: #0369a1; }

  .status-coming {
    opacity: 0.65;
    background: rgba(250, 250, 250, 0.8);
  }
  .status-coming:hover {
    transform: none;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.02);
    border-color: #e2e8f0;
  }
</style>
